{
  "name": "vchat7",
  "version": "1.3.0",
  "description": "Embeddable AI chatbot widget for React applications",
  "author": "Vaibhav Patil",
  "license": "MIT",
  "homepage": "https://github.com/vaibhav-patil/vchat#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/vaibhav-patil/vchat.git",
    "directory": "sdk"
  },
  "bugs": {
    "url": "https://github.com/vaibhav-patil/vchat/issues"
  },
  "keywords": [
    "chatbot",
    "react",
    "widget",
    "ai",
    "chat",
    "embeddable",
    "streaming",
    "sse",
    "conversational-ai"
  ],
  "type": "module",
  "main": "dist/vchat7-react.umd.js",
  "module": "dist/vchat7-react.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vchat7-react.es.js",
      "require": "./dist/vchat7-react.umd.js"
    },
    "./style.css": "./dist/vchat7.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "~5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0"
  }
}
